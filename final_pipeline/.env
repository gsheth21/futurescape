# ── final_pipeline/.env ───────────────────────────────────────────────────────
# Machine-specific paths and tunable parameters.
# Edit these before running pipeline.py.
# This file is NOT committed to git.

# Path to the superpoint/src/ directory (used for sys.path so imports resolve)
SUPERPOINT_SRC_DIR=/mnt/e/NCSU/Fall_2025/Board Game/superpoint/src

# YOLO model weights
BOARD_YOLO_WEIGHTS=/mnt/e/NCSU/Fall_2025/Board Game/superpoint/src/saved_models/board_detector_v1.pt
PIECE_YOLO_WEIGHTS=/mnt/e/NCSU/Fall_2025/Board Game/piece_detection/red_piece_detection/saved_models/red_piece_detector.pt

# SuperPoint pretrained weights (.pth)
SP_WEIGHTS=/mnt/e/NCSU/Fall_2025/Board Game/superpoint/SuperPointPretrainedNetwork/pretrained/superpoint_v1.pth

# Directory containing the ideal template files:
#   cropped_ideal_image.png
#   cropped_ideal_image_gt.npy
#   cropped_ideal_image_hex_centers.json
TEMPLATE_DIR=/mnt/e/NCSU/Fall_2025/Board Game/superpoint/raw_dataset/preprocessed/cropped_ideal_templates

# Full path to the hex centers JSON (usually inside TEMPLATE_DIR)
HEX_CENTERS_PATH=/mnt/e/NCSU/Fall_2025/Board Game/superpoint/raw_dataset/preprocessed/cropped_ideal_templates/cropped_ideal_image_hex_centers.json

# Detection confidence thresholds
BOARD_CONF=0.5
PIECE_CONF=0.5

# Fractional padding added around the detected board bounding box
BOARD_PAD=0.05
