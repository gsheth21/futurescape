# ============================================================
# Board Keypoint Prediction - Machine-Specific Configuration
# ============================================================
# Copy this file to .env and adjust paths for your machine.

# ---- Module Base Directory ----
# Absolute or relative path to the board_keypoint_prediction/ folder.
# Used by notebooks to resolve all other dataset/output paths.
KEYPOINT_BASE_DIR=..

# ---- Augmentation Dataset ----
# Root of the keypoint dataset fed into keypoint_dataaug.py
# (contains images/ and labels/ subdirs)
AUG_DATASET_DIR=../yolo_keypoint_dataset

# ---- Label Conversion (convert_to_keypoint.py) ----
# Label Studio JSON export file
LABEL_STUDIO_JSON=../yolo_keypoint_dataset/yolo_keypoint_dataset.json
# Output directory for converted YOLO pose labels
LABEL_OUTPUT_DIR=../yolo_keypoint_dataset/labels

# ---- Verification (verify_augmentations.py) ----
# Root of augmented dataset to verify (contains images_aug/ and labels_aug/)
VERIFY_DATASET_DIR=../yolo_keypoint_dataset

# ---- Coordinate Finder (find_coordinates.py) ----
# Path to the reference image for interactive hex-center clicking
IDEAL_IMAGE_PATH=../ideal_image.png

# ---- Model Weights ----
# Pre-trained YOLO pose weights to start training from.
# Download from: https://github.com/ultralytics/assets/releases
PRETRAINED_MODEL=yolov8m-pose.pt
