# ============================================================
# Board Detection - Machine-Specific Configuration
# ============================================================
# Copy this file to .env and adjust paths for your machine.
# Do NOT commit .env to version control.

# ---- Dataset Paths ----
# Root dataset directory (relative to src/ or absolute)
DATASET_DIR=../datasets/bounding_box_dataset

# Root directory for data_augmentation.py input data
AUG_DATASET_DIR=../datasets/segmented_dataset

# ---- Model Weights ----
# Pre-trained YOLO weights to start training from
# Download yolov8n.pt from: https://github.com/ultralytics/assets/releases
PRETRAINED_MODEL=yolov8n.pt

# ---- Output Paths ----
# Directory to save trained model weights
MODEL_SAVE_DIR=saved_models

# Filename for the saved model
MODEL_SAVE_NAME=board_detector_v1.pt

# ---- Augmentation Settings ----
# Number of augmented copies to generate per original image
N_AUGS=10
