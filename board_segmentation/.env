# ============================================================
# Board Segmentation - Machine-Specific Configuration
# ============================================================
# Copy this file to .env and adjust paths for your machine.

# ---- Module Base Directory ----
# Absolute or relative path to board_segmentation/ folder.
# Used by notebooks to resolve dataset and output paths.
SEG_BASE_DIR=..

# ---- Augmentation Dataset ----
# Root of the dataset fed into polyseg_datasug.py
# (contains images/ and labels/ subdirs with polygon annotations)
AUG_DATASET_DIR=../board_segmentation_dataset

# ---- Model Weights ----
# Pre-trained YOLO segmentation weights to start training from.
# Download from: https://github.com/ultralytics/assets/releases
PRETRAINED_MODEL=yolov8m-seg.pt
