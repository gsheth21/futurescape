# ── Input / Output ───────────────────────────────────────────────────────────
# Absolute path to directory containing images to auto-label
IMAGES_DIR=/mnt/e/NCSU/Fall_2025/Board Game/psuedo_labeling/dataset/images

# Absolute path to directory where YOLO .txt label files will be written
LABELS_DIR=/mnt/e/NCSU/Fall_2025/Board Game/psuedo_labeling/dataset/labels

# ── Model Weights ─────────────────────────────────────────────────────────────
# Absolute path to trained board detection model (.pt)
BOARD_MODEL_PATH=/mnt/e/NCSU/Fall_2025/Board Game/superpoint/src/saved_models/board_detector_v1.pt

# Absolute path to piece detection model (.pt)
# Use a single-class model (e.g. yellow_piece_detector.pt) with DETECTION_MODE=single
# Use the all-pieces model (e.g. all_pieces_detector.pt) with DETECTION_MODE=multi
PIECE_MODEL_PATH=/mnt/e/NCSU/Fall_2025/Board Game/piece_detection/src/yellow_piece_detection/saved_models/yellow_piece_detector.pt

# ── Detection Thresholds ──────────────────────────────────────────────────────
BOARD_CONF=0.3
PIECE_CONF=0.25

# ── Detection Mode ────────────────────────────────────────────────────────────
# single  → single-class model; every detection is labelled with CLASS_ID below
# multi   → multi-class model (all-pieces); class IDs come from the model output
DETECTION_MODE=single

# ── Label Config (single mode only) ──────────────────────────────────────────
# YOLO class ID written into each label file when DETECTION_MODE=single
CLASS_ID=0
