# =============================================================================
# SuperPoint Module — Environment Configuration
# Copy this file and fill in paths for your machine.
# None of the values below are committed — add .env to .gitignore.
# =============================================================================

# ── SuperPoint pretrained weights ─────────────────────────────────────────────
# Download from: https://github.com/magicleap/SuperPointPretrainedNetwork
SP_WEIGHTS=/mnt/e/NCSU/Fall_2025/Board Game/superpoint/SuperPointPretrainedNetwork/pretrained/superpoint_v1.pth

# ── YOLO board detector weights (trained in map_detection module) ─────────────
YOLO_BOARD_WEIGHTS=/mnt/e/NCSU/Fall_2025/Board Game/map_detection/saved_models/board_detector_v1.pt

# =============================================================================
# Full-image pipeline  (no_crop/)
# =============================================================================

# Folder containing the ideal template image(s) + precomputed .npy tensors
TEMPLATE_DIR=/mnt/e/NCSU/Fall_2025/Board Game/superpoint/raw_dataset/preprocessed/ideal_templates

# Folder containing test images to run inference on
TEST_IMAGE_DIR=/mnt/e/NCSU/Fall_2025/Board Game/superpoint/raw_dataset

# Where run_pipeline.py writes *_pred.npy, *_matches.png, *_pred.png
RESULTS_DIR=/mnt/e/NCSU/Fall_2025/Board Game/superpoint/raw_dataset

# .npy file of canonical keypoints clicked on the ideal template
CANONICAL_KPS_PATH=/mnt/e/NCSU/Fall_2025/Board Game/superpoint/raw_dataset/preprocessed/ideal_templates/ideal_image_gt.npy

# Folders used by evaluator.py
GT_DIR=/mnt/e/NCSU/Fall_2025/Board Game/superpoint/raw_dataset/preprocessed/new_test_images
PRED_DIR=/mnt/e/NCSU/Fall_2025/Board Game/superpoint/raw_dataset/preprocessed/new_test_images_results

# =============================================================================
# Cropped pipeline  (with_crop/)
# =============================================================================

# Folder containing the cropped ideal template image(s) + precomputed .npy tensors
CROPPED_TEMPLATE_DIR=/mnt/e/NCSU/Fall_2025/Board Game/superpoint/raw_dataset/preprocessed/cropped_ideal_templates

# Folder containing full-size test images (YOLO crops them at runtime)
CROPPED_TEST_IMAGE_DIR=/mnt/e/NCSU/Fall_2025/Board Game/superpoint/raw_dataset/preprocessed/test_images

# Where run_pipeline_cropped.py writes *_pred.npy, *_bbox.npy, *_crop.png, etc.
CROPPED_RESULTS_DIR=/mnt/e/NCSU/Fall_2025/Board Game/superpoint/raw_dataset/preprocessed/cropped_test_images_results

# .npy file of canonical keypoints clicked on the cropped ideal template
CROPPED_CANONICAL_KPS_PATH=/mnt/e/NCSU/Fall_2025/Board Game/superpoint/raw_dataset/preprocessed/cropped_ideal_templates/cropped_ideal_image_gt.npy

# Folders used by cropped_eval.py
CROPPED_GT_DIR=/mnt/e/NCSU/Fall_2025/Board Game/superpoint/raw_dataset/preprocessed/test_images
CROPPED_PRED_DIR=/mnt/e/NCSU/Fall_2025/Board Game/superpoint/raw_dataset/preprocessed/cropped_test_images_results
