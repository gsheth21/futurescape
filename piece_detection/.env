# =============================================================================
# Piece Detection — machine-specific paths
# Set ALL values to absolute paths on your machine before running any notebook
# or script. This file is not committed to version control.
# =============================================================================

# ---------------------------------------------------------------------------
# Dataset roots
# ---------------------------------------------------------------------------

DATASET_DIR=/path/to/datasets

# Root directory that contains all per-piece raw label subdirectories.
# Used by dataset_creator.py to discover and merge class subdirs.
PIECES_DATASET_DIR=${DATASET_DIR}/pieces_dataset

# Merged all-pieces YOLO dataset (output of dataset_creator.py).
ALL_PIECES_DATASET_DIR=${PIECES_DATASET_DIR}/all_pieces

# ---------------------------------------------------------------------------
# Per-piece raw label directories
# Each should point to the folder that contains images/ and labels/ subfolders.
# ---------------------------------------------------------------------------

AQUATIC_LIFE_LABELS_DIR=${PIECES_DATASET_DIR}/aquatic_life

BLACK_LABELS_DIR=${PIECES_DATASET_DIR}/black_pieces

MILITARY_LABELS_DIR=${PIECES_DATASET_DIR}/military_installation

RED_LABELS_DIR=${PIECES_DATASET_DIR}/red_pieces

SITE_INTERVENTION_LABELS_DIR=${PIECES_DATASET_DIR}/site_intervention

WILDLIFE_LABELS_DIR=${PIECES_DATASET_DIR}/wildlife

YEAR_LABELS_DIR=${DATASET_DIR}/year

YELLOW_LABELS_DIR=${PIECES_DATASET_DIR}/yellow_pieces

# ---------------------------------------------------------------------------
# Model weights
# ---------------------------------------------------------------------------

# Board detector model — produced by the superpoint module.
# Download or train it first, then set this to the absolute path of the .pt file.
BOARD_DETECTOR_MODEL=/path/to/superpoint/src/saved_models/board_detector_v1.pt
